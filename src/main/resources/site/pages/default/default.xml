<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<page xmlns="urn:enonic:xp:model:1.0">
  <display-name i18n="default.displayName">Default</display-name>
  <description i18n="default.description">Default page view adding headers with menus and footer</description>

  <form>
    <input name="showWithAside" type="CheckBox">
      <label i18n="default.showWithAside">Show With Aside</label>
      <default>checked</default>
    </input>
  </form>

  <regions>
    <region name="header"/>
    <region name="main"/>
    <region name="aside"/>
  </regions>
</page>
