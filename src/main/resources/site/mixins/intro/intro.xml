<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<mixin xmlns="urn:enonic:xp:model:1.0">
  <display-name i18n="common.intro">Intro</display-name>

  <form>
    <input name="intro" type="HtmlArea">
      <label i18n="common.intro">Intro</label>
      <occurrences minimum="0" maximum="1"/>
      <config>
        <exclude>*</exclude>
        <include>Bold Italic Strike | RemoveFormat | SpecialChar</include>
      </config>
    </input>
  </form>
</mixin>
